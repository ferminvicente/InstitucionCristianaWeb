<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Ministerio de Educación</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome (segundo) -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- CSS personalizado -->
	<link rel="stylesheet" href="/css/components/Styles - Main.css">
    <link rel="stylesheet" href="/css/components/Styles - Navbar.css">
    <link rel="stylesheet" href="/css/components/Styles - Footer.css">
	<link rel="stylesheet" href="/css/components/Styles - Home.css">
    <link rel="stylesheet" href="~/css/pages/Styles - Nosotros.css">
    <link rel="stylesheet" href="/css/components/Styles - Contacto.css">

</head>
<body>
    <!-- Navbar desde Partial View -->
    @await Html.PartialAsync("_Navbar")

    <!-- Contenido de las vistas -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer desde Partial View -->
    @await Html.PartialAsync("_Footer")


    <!-- Enlace en el menú de navegación -->
    <li class="nav-item">
        <a class="nav-link" asp-controller="Nosotros" asp-action="Nosotros">Nosotros</a>
    </li>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>