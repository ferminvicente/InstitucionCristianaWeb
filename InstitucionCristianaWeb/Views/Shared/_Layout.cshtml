<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Ministerio de Educación</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome (segundo) -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- CSS personalizado -->
	<link rel="stylesheet" href="/css/components/Styles - Main.css">
    <link rel="stylesheet" href="/css/components/Styles - Navbar.css">
    <link rel="stylesheet" href="/css/components/Styles - Footer.css">
    <link rel="stylesheet" href="~/css/pages/Styles - Home.css">
    <link rel="stylesheet" href="~/css/pages/Styles - Nosotros.css">
    <link rel="stylesheet" href="~/css/pages/Styles - Programas.css">
    <link rel="stylesheet" href="~/css/pages/Styles - Biblioteca.css">
    <link rel="stylesheet" href="/css/components/Styles - Contacto.css">

</head>
<body>
    <!-- Navbar desde Partial View -->
    @await Html.PartialAsync("_Navbar")

    <!-- Contenido de las vistas -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer desde Partial View -->
    @await Html.PartialAsync("_Footer")

    <!-- Scripts Globales -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Scripts Específicos para pagina biblioteca -->
    @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Biblioteca")
    {
        <script src="~/js/Biblioteca.js"></script>
    }

    <!-- Scripts Específicos para pagina progrmas -->
    @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Programas")
    {
        <link rel="stylesheet" href="~/css/components/Styles-Programas.css">
        <script src="~/js/Programas.js"></script>
    }

    <!-- Scripts Específicos para pagina Home -->
    @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Home")
    {
        <link rel="stylesheet" href="~/css/pages/Styles - Home.css">
        <script src="~/js/Home.js"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>