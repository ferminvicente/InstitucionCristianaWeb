@{
    ViewData["Title"] = "Biblioteca Digital";
    Layout = "_Layout";
}

<section class="biblioteca-hero">
    <div class="container">
        <h1>Biblioteca Digital</h1>
        <p class="hero-subtitle">Explora nuestra colección de recursos educativos y espirituales</p>
    </div>
</section>

<section class="categorias-biblioteca">
    <div class="container">
        <h2 class="titulo-seccion">Categorías de Recursos</h2>
        
        <!-- Contenedor del slider CORREGIDO -->
        <div class="categorias-slider-container">
            <div class="categorias-slider">
                <!-- Tarjeta 1 - Teología -->
                <div class="categoria-card">
                    <div class="categoria-icono">
                        <i class="fas fa-bible"></i>
                    </div>
                    <h3>Teología</h3>
                    <p>Estudios bíblicos, doctrina cristiana, comentarios y recursos teológicos profundos.</p>
                    <div class="categoria-stats">
                        <span class="stat">250+ Libros</span>
                        <span class="stat">50 Estudios</span>
                    </div>
                    <button class="btn-explorar">Explorar Colección</button>
                </div>

                <!-- Tarjeta 2 - Autoayuda -->
                <div class="categoria-card">
                    <div class="categoria-icono">
                        <i class="fas fa-hands-helping"></i>
                    </div>
                    <h3>Crecimiento Personal</h3>
                    <p>Recursos para desarrollo personal, liderazgo y crecimiento espiritual práctico.</p>
                    <div class="categoria-stats">
                        <span class="stat">180+ Recursos</span>
                        <span class="stat">30 Guías</span>
                    </div>
                    <button class="btn-explorar">Explorar Colección</button>
                </div>

                <!-- Tarjeta 3 - Educación -->
                <div class="categoria-card">
                    <div class="categoria-icono">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h3>Educación Cristiana</h3>
                    <p>Material pedagógico, currículos educativos y recursos para enseñanza cristiana.</p>
                    <div class="categoria-stats">
                        <span class="stat">120+ Materiales</span>
                        <span class="stat">25 Planes</span>
                    </div>
                    <button class="btn-explorar">Explorar Colección</button>
                </div>

                <!-- Tarjeta 4 - Familia -->
                <div class="categoria-card">
                    <div class="categoria-icono">
                        <i class="fas fa-home"></i>
                    </div>
                    <h3>Familia y Matrimonio</h3>
                    <p>Recursos para fortalecer la familia, matrimonio y crianza con valores cristianos.</p>
                    <div class="categoria-stats">
                        <span class="stat">95+ Libros</span>
                        <span class="stat">20 Seminarios</span>
                    </div>
                    <button class="btn-explorar">Explorar Colección</button>
                </div>

                <!-- Tarjeta 5 - Juventud -->
                <div class="categoria-card">
                    <div class="categoria-icono">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Juventud y Adolescentes</h3>
                    <p>Material especializado para ministerio juvenil y recursos para jóvenes cristianos.</p>
                    <div class="categoria-stats">
                        <span class="stat">75+ Recursos</span>
                        <span class="stat">15 Programas</span>
                    </div>
                    <button class="btn-explorar">Explorar Colección</button>
                </div>
            </div>
        </div>

        <!-- Controles de navegación -->
        <div class="slider-controls">
            <button class="slider-btn prev-btn">
                <i class="fas fa-chevron-left"></i>
            </button>
            <button class="slider-btn next-btn">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>
</section>