@{
    ViewData["Title"] = "Programas de Estudio";
    Layout = "_Layout";
}

<section class="programas-hero">
    <div class="container">
        <h1>Programas de Estudio</h1>
        <p class="hero-subtitle">Formación integral con excelencia académica y valores cristianos</p>
    </div>
</section>

<section class="programas-grid-section">
    <div class="container">
        <h2 class="titulo-seccion">Nuestros Programas Educativos</h2>

        <!-- Filtros por categoría -->
        <div class="filtros-programas">
            <button class="filtro-btn active" data-categoria="todos">Todos los Programas</button>
            <button class="filtro-btn" data-categoria="teologia">Teología</button>
            <button class="filtro-btn" data-categoria="ministerio">Ministerio</button>
            <button class="filtro-btn" data-categoria="educacion">Educación</button>
            <button class="filtro-btn" data-categoria="liderazgo">Liderazgo</button>
        </div>

        <!-- Grid de Programas -->
        <div class="programas-grid">
            <!-- Programa 1 - Licenciatura en Teología -->
            <div class="programa-card" data-categoria="teologia">
                <div class="programa-header">
                    <div class="programa-icono">
                        <i class="fas fa-bible"></i>
                    </div>
                    <h3>Licenciatura en Teología</h3>
                    <span class="programa-nivel">Pregrado</span>
                </div>
                <div class="programa-body">
                    <p class="programa-descripcion">
                        Formación teológica integral para el servicio ministerial y la investigación bíblica.
                    </p>
                    <ul class="programa-caracteristicas">
                        <li><i class="fas fa-clock"></i> Duración: 4 años</li>
                        <li><i class="fas fa-book"></i> 48 asignaturas</li>
                        <li><i class="fas fa-user-graduate"></i> Titulación: Licenciado</li>
                    </ul>
                </div>
                <div class="programa-footer">
                    <div class="programa-precio">
                        <span class="precio">$180/mes</span>
                        <span class="modalidad">En línea</span>
                    </div>
                    <button class="btn-programa btn-info">Más Información</button>
                    <button class="btn-programa btn-inscribir">Inscribirse</button>
                </div>
            </div>

            <!-- Programa 2 - Maestría en Ministerio -->
            <div class="programa-card" data-categoria="ministerio">
                <div class="programa-header">
                    <div class="programa-icono">
                        <i class="fas fa-church"></i>
                    </div>
                    <h3>Maestría en Ministerio Pastoral</h3>
                    <span class="programa-nivel">Posgrado</span>
                </div>
                <div class="programa-body">
                    <p class="programa-descripcion">
                        Especialización para el liderazgo pastoral y la administración de iglesias.
                    </p>
                    <ul class="programa-caracteristicas">
                        <li><i class="fas fa-clock"></i> Duración: 2 años</li>
                        <li><i class="fas fa-book"></i> 36 créditos</li>
                        <li><i class="fas fa-user-graduate"></i> Titulación: Magíster</li>
                    </ul>
                </div>
                <div class="programa-footer">
                    <div class="programa-precio">
                        <span class="precio">$220/mes</span>
                        <span class="modalidad">Semipresencial</span>
                    </div>
                    <button class="btn-programa btn-info">Más Información</button>
                    <button class="btn-programa btn-inscribir">Inscribirse</button>
                </div>
            </div>

            <!-- Programa 3 - Diplomado en Educación Cristiana -->
            <div class="programa-card" data-categoria="educacion">
                <div class="programa-header">
                    <div class="programa-icono">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h3>Diplomado en Educación Cristiana</h3>
                    <span class="programa-nivel">Diplomado</span>
                </div>
                <div class="programa-body">
                    <p class="programa-descripcion">
                        Formación especializada para educadores en instituciones cristianas.
                    </p>
                    <ul class="programa-caracteristicas">
                        <li><i class="fas fa-clock"></i> Duración: 8 meses</li>
                        <li><i class="fas fa-book"></i> 12 módulos</li>
                        <li><i class="fas fa-user-graduate"></i> Certificación: Diplomado</li>
                    </ul>
                </div>
                <div class="programa-footer">
                    <div class="programa-precio">
                        <span class="precio">$120/mes</span>
                        <span class="modalidad">En línea</span>
                    </div>
                    <button class="btn-programa btn-info">Más Información</button>
                    <button class="btn-programa btn-inscribir">Inscribirse</button>
                </div>
            </div>

            <!-- Programa 4 - Doctorado en Liderazgo -->
            <div class="programa-card" data-categoria="liderazgo">
                <div class="programa-header">
                    <div class="programa-icono">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Doctorado en Liderazgo Cristiano</h3>
                    <span class="programa-nivel">Doctorado</span>
                </div>
                <div class="programa-body">
                    <p class="programa-descripcion">
                        Programa doctoral para la investigación y desarrollo del liderazgo cristiano.
                    </p>
                    <ul class="programa-caracteristicas">
                        <li><i class="fas fa-clock"></i> Duración: 3 años</li>
                        <li><i class="fas fa-book"></i> 60 créditos</li>
                        <li><i class="fas fa-user-graduate"></i> Titulación: Doctor</li>
                    </ul>
                </div>
                <div class="programa-footer">
                    <div class="programa-precio">
                        <span class="precio">$350/mes</span>
                        <span class="modalidad">Presencial</span>
                    </div>
                    <button class="btn-programa btn-info">Más Información</button>
                    <button class="btn-programa btn-inscribir">Inscribirse</button>
                </div>
            </div>

            <!-- Programa 5 - Bachillerato en Teología -->
            <div class="programa-card" data-categoria="teologia">
                <div class="programa-header">
                    <div class="programa-icono">
                        <i class="fas fa-cross"></i>
                    </div>
                    <h3>Bachillerato en Teología</h3>
                    <span class="programa-nivel">Pregrado</span>
                </div>
                <div class="programa-body">
                    <p class="programa-descripcion">
                        Formación básica en teología para el servicio ministerial inicial.
                    </p>
                    <ul class="programa-caracteristicas">
                        <li><i class="fas fa-clock"></i> Duración: 3 años</li>
                        <li><i class="fas fa-book"></i> 36 asignaturas</li>
                        <li><i class="fas fa-user-graduate"></i> Titulación: Bachiller</li>
                    </ul>
                </div>
                <div class="programa-footer">
                    <div class="programa-precio">
                        <span class="precio">$150/mes</span>
                        <span class="modalidad">En línea</span>
                    </div>
                    <button class="btn-programa btn-info">Más Información</button>
                    <button class="btn-programa btn-inscribir">Inscribirse</button>
                </div>
            </div>

            <!-- Programa 6 - Especialización en Consejería -->
            <div class="programa-card" data-categoria="ministerio">
                <div class="programa-header">
                    <div class="programa-icono">
                        <i class="fas fa-hands-helping"></i>
                    </div>
                    <h3>Especialización en Consejería Cristiana</h3>
                    <span class="programa-nivel">Especialización</span>
                </div>
                <div class="programa-body">
                    <p class="programa-descripcion">
                        Formación en consejería bíblica para el acompañamiento espiritual.
                    </p>
                    <ul class="programa-caracteristicas">
                        <li><i class="fas fa-clock"></i> Duración: 18 meses</li>
                        <li><i class="fas fa-book"></i> 24 créditos</li>
                        <li><i class="fas fa-user-graduate"></i> Titulación: Especialista</li>
                    </ul>
                </div>
                <div class="programa-footer">
                    <div class="programa-precio">
                        <span class="precio">$200/mes</span>
                        <span class="modalidad">Semipresencial</span>
                    </div>
                    <button class="btn-programa btn-info">Más Información</button>
                    <button class="btn-programa btn-inscribir">Inscribirse</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Sección de Beneficios -->
<section class="beneficios-programas">
    <div class="container">
        <h2 class="titulo-seccion">Beneficios de Estudiar con Nosotros</h2>
        <div class="beneficios-grid">
            <div class="beneficio-card">
                <i class="fas fa-award"></i>
                <h4>Certificación Oficial</h4>
                <p>Programas reconocidos por el Ministerio de Educación</p>
            </div>
            <div class="beneficio-card">
                <i class="fas fa-user-tie"></i>
                <h4>Profesores Calificados</h4>
                <p>Docentes con amplia experiencia ministerial y académica</p>
            </div>
            <div class="beneficio-card">
                <i class="fas fa-laptop"></i>
                <h4>Modalidad Flexible</h4>
                <p>Estudia en línea, presencial o semipresencial</p>
            </div>
            <div class="beneficio-card">
                <i class="fas fa-hand-holding-heart"></i>
                <h4>Becas Disponibles</h4>
                <p>Programas de becas para estudiantes destacados</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-programas">
    <div class="container">
        <div class="cta-content">
            <h2>¿Listo para comenzar tu formación?</h2>
            <p>Únete a nuestra comunidad de más de 15,000 estudiantes graduados</p>
            <div class="cta-buttons">
                <button class="btn-cta btn-cta-primary">Solicitar Información</button>
                <button class="btn-cta btn-cta-secondary">Ver Proceso de Admisión</button>
            </div>
        </div>
    </div>
</section>