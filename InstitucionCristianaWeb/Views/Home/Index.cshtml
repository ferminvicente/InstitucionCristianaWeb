<section class="estadisticas-home">
    <div class="container">
        <div class="row">
            <div class="col-md-3 col-6">
                <div class="estadistica-item">
                    <span class="estadistica-numero">15,000+</span>
                    <p class="estadistica-texto">Estudiantes Formados</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="estadistica-item">
                    <span class="estadistica-numero">250+</span>
                    <p class="estadistica-texto">Instituciones Afiliadas</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="estadistica-item">
                    <span class="estadistica-numero">30+</span>
                    <p class="estadistica-texto">Años de Servicio</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="estadistica-item">
                    <span class="estadistica-numero">12</span>
                    <p class="estadistica-texto">Programas Activos</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Misión y Visión -->
<section class="mision-vision-home">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <div class="card-mision">
                    <h2>Nuestra Misión</h2>
                    <p>Formar líderes cristianos integrales mediante programas educativos de excelencia, fundamentados en valores bíblicos y comprometidos con el servicio a la comunidad.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card-vision">
                    <h2>Nuestra Visión</h2>
                    <p>Ser la institución educativa cristiana de referencia a nivel nacional, reconocida por su innovación pedagógica y su impacto transformador en la sociedad.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Valores -->
<section class="valores-home">
    <div class="container">
        <h2 class="titulo-seccion">Valores Fundamentales</h2>
        <div class="row">
            <div class="col-lg-4 col-md-6">
                <div class="card-valor">
                    <i class="fas fa-bible icono-valor"></i>
                    <h3>Fe Cristiana</h3>
                    <p>Fundamentamos nuestra labor educativa en los principios y valores del Evangelio de Cristo.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="card-valor">
                    <i class="fas fa-graduation-cap icono-valor"></i>
                    <h3>Excelencia Académica</h3>
                    <p>Comprometidos con los más altos estándares de calidad en todos nuestros programas educativos.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="card-valor">
                    <i class="fas fa-hands-helping icono-valor"></i>
                    <h3>Servicio Integral</h3>
                    <p>Formamos profesionales comprometidos con el servicio a Dios, la familia y la comunidad.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Compromiso -->
<section class="compromiso-home">
    <div class="container">
        <h2 class="titulo-seccion">Nuestro Compromiso</h2>
        <ul class="lista-compromiso">
            <li class="item-compromiso">Proveer educación accesible y de calidad para todos los sectores sociales</li>
            <li class="item-compromiso">Formar ciudadanos íntegros, éticos y socialmente responsables</li>
            <li class="item-compromiso">Innovar constantemente en metodologías y tecnologías educativas</li>
            <li class="item-compromiso">Mantener alianzas estratégicas con instituciones de prestigio</li>
            <li class="item-compromiso">Fomentar el desarrollo espiritual junto al crecimiento académico</li>
        </ul>
    </div>
</section>