<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Programas Académicos - Institución Cristiana</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .hero-programas {
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('img/programas-hero.jpg') center/cover;
            height: 60vh;
            display: flex;
            align-items: center;
        }

        .card-programa {
            transition: transform 0.3s;
            border: none;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

            .card-programa:hover {
                transform: translateY(-10px);
            }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="index.html">
                <img src="/img/logo-horizontal.png" alt="Logo Ministerio" style="height: 50px;">
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="index.html">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="nosotros.html">Nosotros</a></li>
                    <li class="nav-item"><a class="nav-link" href="programas.html">Programas</a></li>
                    <li class="nav-item"><a class="nav-link" href="contacto.html">Contacto</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-programas text-white text-center">
        <div class="container">
            <h1 class="display-4 mb-4">Nuestros Programas</h1>
            <p class="lead">Educación de calidad desde preescolar hasta bachillerato</p>
        </div>
    </section>

    <!-- Programas Académicos -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Oferta Educativa</h2>
            <div class="row g-4">
                <!-- Preescolar -->
                <div class="col-md-4">
                    <div class="card card-programa h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-baby-carriage fa-3x text-primary mb-3"></i>
                            <h4 class="card-title">Preescolar</h4>
                            <p class="card-text">Estimulación temprana con valores cristianos para niños de 3 a 5 años.</p>
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success me-2"></i>Juego guiado</li>
                                <li><i class="fas fa-check text-success me-2"></i>Inglés básico</li>
                                <li><i class="fas fa-check text-success me-2"></i>Actividades lúdicas</li>
                            </ul>
                            <a href="#" class="btn btn-primary">Más información</a>
                        </div>
                    </div>
                </div>

                <!-- Primaria -->
                <div class="col-md-4">
                    <div class="card card-programa h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-book-open fa-3x text-primary mb-3"></i>
                            <h4 class="card-title">Primaria</h4>
                            <p class="card-text">Formación integral con énfasis en lectura crítica y matemáticas.</p>
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success me-2"></i>Programa bilingüe</li>
                                <li><i class="fas fa-check text-success me-2"></i>Robótica educativa</li>
                                <li><i class="fas fa-check text-success me-2"></i>Deportes</li>
                            </ul>
                            <a href="#" class="btn btn-primary">Más información</a>
                        </div>
                    </div>
                </div>

                <!-- Bachillerato -->
                <div class="col-md-4">
                    <div class="card card-programa h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-graduation-cap fa-3x text-primary mb-3"></i>
                            <h4 class="card-title">Bachillerato</h4>
                            <p class="card-text">Preparación universitaria con orientación vocacional cristiana.</p>
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success me-2"></i>Programa STEM</li>
                                <li><i class="fas fa-check text-success me-2"></i>Liderazgo cristiano</li>
                                <li><i class="fas fa-check text-success me-2"></i>Servicio comunitario</li>
                            </ul>
                            <a href="#" class="btn btn-primary">Más información</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Programas Especiales -->
    <section class="bg-light py-5">
        <div class="container">
            <h2 class="text-center mb-5">Programas Complementarios</h2>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="row g-0">
                            <div class="col-md-4 bg-primary text-white d-flex align-items-center justify-content-center">
                                <i class="fas fa-music fa-3x"></i>
                            </div>
                            <div class="col-md-8">
                                <div class="card-body">
                                    <h5>Escuela de Música</h5>
                                    <p>Clases de instrumentos y coro infantil.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="row g-0">
                            <div class="col-md-4 bg-success text-white d-flex align-items-center justify-content-center">
                                <i class="fas fa-futbol fa-3x"></i>
                            </div>
                            <div class="col-md-8">
                                <div class="card-body">
                                    <h5>Escuela Deportiva</h5>
                                    <p>Fútbol, baloncesto y voleibol competitivo.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer (Igual que en Nosotros) -->
    <footer class="bg-primary text-white py-5 mt-5">
        <div class="container">
            <div class="row">
                <!-- Columna Logo -->
                <div class="col-md-4 text-center mb-4">
                    <img src="/img/logo-vertical.png" alt="Logo Vertical" class="img-fluid" style="max-height: 150px;">
                </div>

                <!-- Columna Contacto -->
                <div class="col-md-4">
                    <h4 class="text-secondary mb-3">Contacto</h4>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-map-marker-alt me-2 text-secondary"></i>
                            Av. Bolívar Esq. Leopoldo Navarro, Santo Domingo
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-phone me-2 text-secondary"></i>
                            (809) 123-4567
                        </li>
                        <li>
                            <i class="fas fa-envelope me-2 text-secondary"></i>
                            info@mineduc.gob.do
                        </li>
                    </ul>
                </div>

                <!-- Columna Redes -->
                <div class="col-md-4">
                    <h4 class="text-secondary mb-3">Síguenos</h4>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-white fs-3"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-white fs-3"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-white fs-3"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>

            <div class="border-top border-secondary pt-4 mt-4 text-center">
                <p class="mb-0">&copy; 2024 Ministerio Nacional de Educación - República Dominicana</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>